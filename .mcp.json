{
  "mcpServers": {
    "netchecker": {
      "command": "node",
      "args": [
        "/Users/shakhzod/Documents/GitHub/NetChecker/netchecker-mcp.js"
      ],
      "env": {
        "NETCHECKER_URL": "http://10.10.20.47:9876"
      }
    },
    "claude-flow": {
      "command": "npx",
      "args": [
        "-y",
        "@claude-flow/cli@latest",
        "mcp",
        "start"
      ],
      "env": {
        "npm_config_update_notifier": "false",
        "CLAUDE_FLOW_MODE": "v3",
        "CLAUDE_FLOW_HOOKS_ENABLED": "true",
        "CLAUDE_FLOW_TOPOLOGY": "hierarchical-mesh",
        "CLAUDE_FLOW_MAX_AGENTS": "15",
        "CLAUDE_FLOW_MEMORY_BACKEND": "hybrid"
      },
      "autoStart": false
    }
  }
}